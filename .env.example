# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=xxxxxxxxxxxxx
DB_DATABASE=kasipos

# JWT Configuration
JWT_SECRET=xxxxxx
JWT_EXPIRES_IN=7d

# General Password (admin backup access)
# Generate with: npm run generate:general-password
GENERAL_PASSWORD_HASH=

# OTP / signup email verification. Code length 4–8 digits (signup uses 6); expiry in minutes.
# When NODE_ENV=development, signup verify code is always 123456 (not random).
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=10

# Email (Resend) — signup verification codes. https://resend.com/docs/send-with-nodejs
RESEND_API_KEY=
RESEND_FROM=KasiPOS <onboarding@resend.dev>

# SMS (WinSMS - South Africa) HTTP API. WinSMS Client Zone account credentials.
WINSMS_USERNAME=
WINSMS_PASSWORD=

# Application Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:9002

# =================================================================
# DIGITALOCEAN SPACES / S3 CONFIGURATION
# =================================================================
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_REGION=xxxxx
DO_SPACES_ACCESS_KEY_ID=xxxxxx
DO_SPACES_SECRET_ACCESS_KEY="xxxxxxx" 
DO_SPACES_BUCKET=ai-mobile
MAX_FILE_SIZE=2097152