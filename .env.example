# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=xxxxxxxxxxxxx
DB_DATABASE=kasipos

# JWT Configuration
JWT_SECRET=xxxxxx
JWT_EXPIRES_IN=7d

# OTP Service Configuration
OTP_API_URL=https://otp.ai-mobile.africa/v1/otp
OTP_API_KEY=xxxxxxxxxxxxxxx

# SMS (WinSMS - South Africa). Set WINSMS_API_KEY to send SMS via WinSMS.
# Optional: WINSMS_API_URL (default: https://www.winsms.co.za/api/rest/v1)
WINSMS_API_KEY=
# WINSMS_API_URL=https://www.winsms.co.za/api/rest/v1

# Application Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:9002

# =================================================================
# DIGITALOCEAN SPACES / S3 CONFIGURATION
# =================================================================
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_REGION=xxxxx
DO_SPACES_ACCESS_KEY_ID=xxxxxx
DO_SPACES_SECRET_ACCESS_KEY="xxxxxxx" 
DO_SPACES_BUCKET=ai-mobile
MAX_FILE_SIZE=2097152